# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3001
# URL(s) frontend autorisées (séparées par virgule si plusieurs)
# En prod Railway : https://argonath-app.up.railway.app
FRONTEND_URL=http://localhost:3000

# ── Hedera ────────────────────────────────────────────────────────────────────
RPC_URL=https://testnet.hashio.io/api
HEDERA_PRIVATE_KEY=0x...          # clé privée du compte deployer/admin
HEDERA_ACCOUNT_ID=0.0.XXXXX
ADMIN_PRIVATE_KEY=0x...           # même valeur que HEDERA_PRIVATE_KEY pour le PoC
BACKEND_PRIVATE_KEY=0x...         # clé pour signer les autorisations EIP-712

# ── Contrats déployés ─────────────────────────────────────────────────────────
CLAIM_REGISTRY_ADDRESS=0x...
BOND_METADATA_ADDRESS=0x...

# ── Hedera Token Service / HCS ─────────────────────────────────────────────────
HTS_TOKEN_ID=0.0.XXXXX            # Token ID ARGN (ex: 0.0.8325163)
HCS_TOPIC_ID=0.0.XXXXX            # Topic HCS (ex: 0.0.8326019)

# ── Auth dépositaire ──────────────────────────────────────────────────────────
DEPOSITARY_PASSWORD=changeme      # Mot de passe interface dépositaire

# ── OTP (Verifyway) ───────────────────────────────────────────────────────────
VERIFYWAY_API_KEY=your_key_here
